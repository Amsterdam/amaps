{
  "name": "amaps",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build --config vite.config.ts",
    "build:embed": "vite build --config vite.config.embed.ts",
    "build": "npm run build:embed && npm run build:web && npm run merge:dist",
    "merge:dist": "mkdir -p app/dist && cp -r app/dist-embed/* app/dist/ && cp -r public/* app/dist/",
    "dev": "vite",
    "test": "vitest run --coverage",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@amsterdam/design-system-css": "^4.2.0",
    "@amsterdam/design-system-react": "^4.2.0",
    "@amsterdam/design-system-react-icons": "^2.0.0",
    "@react-router/node": "^8.1.0",
    "@react-router/serve": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "emitonoff": "^0.1.1",
    "geojson": "^0.5.0",
    "isbot": "^5.1.44",
    "leaflet": "^1.9.4",
    "leaflet.pattern": "^0.1.0",
    "proj4": "^2.20.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.9",
    "react-router-devtools": "^6.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
